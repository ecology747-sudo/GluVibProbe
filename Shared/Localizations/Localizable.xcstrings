    "onboarding.flow.insulin_visibility.body" : {
      "comment" : "Description text for the insulin visibility onboarding step",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Damit wird die Sichtbarkeit insulinbezogener Metriken und Statistiken aktiviert. Insulinwerte können nur angezeigt werden, wenn Insulinabgabedaten in Apple Health verfügbar sind. Du kannst das jederzeit in den Einstellungen ändern."
