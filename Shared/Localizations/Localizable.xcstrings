    "faq.data_basics.small_insulin_doses_disappear.answer" : {
      "comment" : "Answer explaining why small insulin doses can disappear in GluVib",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn du in den Einstellungen den Priming-Filter (Pen Air Shot) aktiviert hast, kann GluVib sehr kleine Insulineinträge (≤ deinem Schwellenwert) automatisch ausblenden. Das ist für typische Air-Shot-/Priming-Dosen gedacht. Eine kleine Dosis wird nur dann entfernt, wenn innerhalb von 2 Minuten eine größere Dosis desselben Typs (Bolus oder Basal) vorhanden ist. Die Priming-Filterung ist für Pen-Air-Shots gedacht. Wenn du eine Insulinpumpe mit Mikrodosen verwendest, solltest du diese Option deaktiviert lassen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "If you enabled the Priming (Pen Air Shot) filter in Settings, GluVib can automatically exclude very small insulin entries (≤ your threshold). This is designed for typical air shot / priming doses. A small dose is only removed if there is a larger dose of the same type (Bolus or Basal) within 2 minutes. Priming filtering is intended for pen air shots. If you use an insulin pump with micro-doses, keep this option off."
          }
        }
      }
    },
