    },
    "%@ %lld%%" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ %2$lld%%"
          }
        }
      }
    },
    "%@–%@" : {
      "comment" : "A range of glucose levels that fall within the \"Low\" threshold. The first argument is the formatted lower limit of this range. The second argument is the formatted upper limit of this range.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@–%2$@"
          }
        }
      }
    },
    "%@–%@ %@" : {
      "comment" : "A label displaying the current glucose target range, formatted with the glucose unit. The first argument is the string “%arg” or the string “%.1f”. The second argument is the string “%arg” or the string “%.1f”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@–%2$@ %3$@"
          }
        }
      }
    },
    "%@:" : {
      "comment" : "A label followed by its value in a report's meta section. The argument is the label text, and the second is the value text.",
      "isCommentAutoGenerated" : true
    },
    "%@: %@" : {
      "comment" : "A row that displays a title, a value label, and a stepper control. The title is displayed in a smaller font with a blue foreground color. The value label shows the current value, truncated to one line with a scale factor of 0.85. The stepper control is displayed on the trailing side, with a fixed size and a scale effect of 0.78. The first argument is the string “Steps” or the string “Energy”. The second argument is the string “%arg kcal”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@: %2$@"
          }
        }
      }
    },
    "%lld" : {
      "comment" : "A badge displaying the user's activity score. The value inside the badge is replaced with the actual score.",
      "isCommentAutoGenerated" : true
    },
    "%lld bpm" : {
      "comment" : "A title and value displayed in a small card, representing the user's resting heart rate. The argument is the resting heart rate value.",
      "isCommentAutoGenerated" : true
    },
    "%lld g" : {
      "comment" : "A label displaying the number of grams of carbohydrates consumed in a given daypart.",
      "isCommentAutoGenerated" : true
    },
    "%lld h" : {
      "comment" : "A label inside the Y-axis that shows the number of hours corresponding to a given value on the Y-axis. The value is expected to be an integer representing minutes.",
      "isCommentAutoGenerated" : true
    },
    "%lld kcal" : {
      "comment" : "A label displaying the average active energy over the past week. The argument is the average active energy over the past week, formatted as a number followed by \"kcal\".",
      "isCommentAutoGenerated" : true
    },
    "%lld mg/dL" : {
      "comment" : "A value displaying a glucose reading in milligrams per deciliter. The value is rounded to the nearest integer.",
      "isCommentAutoGenerated" : true
    },
    "%lld min" : {
      "comment" : "A label displaying the average number of minutes of workout over the past week. The argument is the average number of minutes of workout over the past week.",
      "isCommentAutoGenerated" : true
    },
    "%lld samples" : {
      "comment" : "A label displaying the number of CGM samples recorded for today.",
      "isCommentAutoGenerated" : true
    },
    "%lld%%" : {
      "comment" : "A label displaying the percentage of time a user's glucose levels are within a healthy range. The value is shown as a percentage followed by a \"%\" symbol.",
      "isCommentAutoGenerated" : true
    },
    "%lld%% / %lld%%" : {
