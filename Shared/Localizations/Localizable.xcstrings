    "faq.general.main_limitations.answer" : {
      "comment" : "Answer explaining the main limitations of GluVib in the general FAQ section",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Output der GluVib App ist durch Vollständigkeit, Zeitpunkt und Qualität der in Apple Health vorhandenen Daten begrenzt. Wenn Werte fehlen, verzögert vorliegen oder von Datenquellen unterschiedlich erfasst werden, können bestimmte Metriken, Diagramme und Zusammenfassungen nicht verfügbar sein oder von anderen Apps abweichen. GluVib verändert fehlende Daten nicht und „repariert“ sie nicht. Wie detailliert und präzise GluVib Informationen darstellen kann, hängt direkt von den in Apple Health verfügbaren Daten ab: Je vollständiger und konsistenter die Eingangsdaten sind, desto umfassender und aussagekräftiger können die Visualisierungen in der App sein."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "GluVib’s output is limited by the completeness, timing, and quality of the data present in Apple Health. If values are missing, delayed, or recorded differently by data sources, certain metrics, charts, and summaries may be unavailable or may differ from other apps. GluVib does not modify or “repair” missing data. The level of detail and accuracy that GluVib can display directly depends on the data available in Apple Health: more complete and consistently recorded input enables more comprehensive and meaningful visualizations within the app."
          }
        }
      }
    },
    "faq.general.main_limitations.question" : {
      "comment" : "Question asking about the main limitations of GluVib in the general FAQ section",
      "extractionState" : "extracted_with_value",
      "localizations" : {
