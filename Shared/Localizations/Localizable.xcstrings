    "faq.general.what_is_gluvib.answer" : {
      "comment" : "Answer explaining what GluVib is in the general FAQ section",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GluVib ist eine Read-only-App zur Analyse, Aggregation und Visualisierung deiner persönlichen Gesundheitsdaten. Sie zeigt Trends, Zusammenfassungen und Diagramme auf Basis der in Apple Health verfügbaren Daten. GluVib verändert, lädt oder teilt keine Gesundheitsdaten. Alle Informationen werden lokal auf dem Gerät verarbeitet und angezeigt, und es werden keine persönlichen Gesundheitsdaten an externe Dienste übertragen. Die App kann vollständig offline genutzt werden, solange die erforderlichen Daten über Apple Health auf dem Gerät verfügbar sind. Ausnahme: Wenn du HbA1c-Laborwerte manuell hinzufügst, werden diese Einträge lokal in der App gespeichert, nicht über iCloud mit anderen Geräten synchronisiert und beim Deinstallieren der App entfernt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "GluVib is a read-only app for analyzing, aggregating, and visualizing your personal health data. It displays trends, summaries, and charts based on the data available in Apple Health. GluVib does not modify, upload, or share health data. All information is processed and displayed locally on the device, and no personal health data is transmitted to external services. The app can be used fully offline, as long as the required data is available on the device via Apple Health. Exception: if you manually add lab values (for example HbA1c), those entries are stored locally inside the app, are not synced to other devices via iCloud, and are removed if the app is uninstalled."
          }
        }
      }
    },
    "faq.general.what_is_gluvib.question" : {
      "comment" : "Question asking what GluVib is in the general FAQ section",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
