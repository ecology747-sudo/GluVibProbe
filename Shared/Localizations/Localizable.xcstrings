    "faq.data_basics.cgm_coverage.answer" : {
      "comment" : "Answer explaining what the CGM coverage percentage means",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies ist ein 24h-Abdeckungsindikator auf Basis von Apple-Health-CGM-(Sensor)Daten. Der Prozentsatz zeigt, wie viel der letzten 24h durch CGM-(Sensor)Messwerte abgedeckt ist, die aktuell in Apple Health verfügbar sind. GluVib verwendet intern Minuten zur Berechnung dieses Wertes, um geräteunabhängig zu bleiben, da Abtastfrequenz und Synchronisationsverhalten je nach CGM-(Sensor)System unterschiedlich sein können. Wenn die Abdeckung niedriger ist, bedeutet das in der Regel, dass bisher weniger Messwerte in Apple Health angekommen sind, zum Beispiel aufgrund verzögerter oder unterbrochener Synchronisation."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "This is a 24-hour coverage indicator based on Apple Health CGM (Sensor) data. The percentage shows how much of the last 24 hours is covered by CGM (Sensor) readings that are currently available in Apple Health. GluVib uses minutes internally to compute this value in a device-agnostic way, because sampling frequency and sync behavior can vary across CGM (Sensor) systems. If coverage is lower, it usually means fewer readings have arrived in Apple Health yet (for example due to delayed or intermittent sync)."
          }
        }
      }
    },
    "faq.data_basics.cgm_coverage.question" : {
      "comment" : "Question asking what the CGM coverage percentage means",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Was bedeutet „CGM-(Sensor)Abdeckung 86 %“?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "What does “CGM (Sensor) Coverage 86%” mean?"
          }
        }
      }
    },
    "faq.data_basics.cgm_delay.answer" : {
      "comment" : "Answer explaining why CGM sensor data can appear delayed",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CGM-(Sensor)Messwerte werden in der Regel zunächst vom Sensor und der zugehörigen Quell-App erfasst und anschließend in Apple Health synchronisiert. Diese Synchronisation kann je nach System, Quell-App, Hintergrundsynchronisation und Gesamtkonfiguration verzögert oder unterbrochen sein. Die GluVib App kann nur anzeigen, was bereits in Apple Health angekommen ist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "CGM (Sensor) readings are typically collected by the sensor and its source app first, and then synced into Apple Health. That synchronization can be delayed or intermittent depending on the system, the source app, background sync behavior, and the overall setup. GluVib can only display what has already arrived in Apple Health."
          }
        }
      }
    },
    "faq.data_basics.cgm_delay.question" : {
