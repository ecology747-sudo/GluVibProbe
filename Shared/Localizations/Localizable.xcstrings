    "faq.hardware_system_requirements.cgm_hardware_needed.answer" : {
      "comment" : "Answer explaining whether CGM sensor hardware is needed",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nein. CGM-(Sensor)Hardware ist optional. Die metabolischen Analysen in GluVib basieren jedoch auf CGM-(Sensor-)Daten. Um die Metabolic-Domain und ihre Premium-Funktionen zu nutzen, müssen CGM-(Sensor)Daten in Apple Health verfügbar sein."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "No. CGM (Sensor) hardware is optional. However, metabolic analytics in GluVib rely on CGM (Sensor) data. To use the Metabolic domain and its Premium features, CGM (Sensor) data must be available in Apple Health."
          }
        }
      }
    },
    "faq.hardware_system_requirements.cgm_hardware_needed.question" : {
