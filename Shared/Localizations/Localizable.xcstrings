    "faq.glossary.active_vs_nutrition_energy.answer" : {
      "comment" : "Answer explaining the difference between Active Energy and Nutrition Energy in the glossary",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktivenergie bezieht sich auf den Energieverbrauch durch körperliche Aktivität, wie er in Apple Health erfasst ist. Nahrungsenergie bezieht sich auf die Energieaufnahme aus Ernährungseinträgen. In GluVib werden beide Metriken auf Basis der in Apple Health verfügbaren Daten angezeigt und können tagesbezogen sowie über auswählbare Zeiträume betrachtet werden. Zielwerte können konfiguriert werden, um Diagrammen und Zusammenfassungen zusätzlichen Kontext zu geben, während die zugrunde liegenden Apple-Health-Daten unverändert bleiben.\n"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Active Energy refers to energy expenditure attributed to physical activity, as recorded in Apple Health. Nutrition Energy refers to energy intake recorded from nutrition entries. In GluVib, both metrics are displayed based on the data available in Apple Health and can be reviewed on a daily basis and across selectable time periods. Target values can be configured to provide context for charts and summaries, while the underlying Apple Health data remains unchanged."
          }
        }
      }
    },
    "faq.glossary.active_vs_nutrition_energy.question" : {
      "comment" : "Question asking about the difference between Active Energy and Nutrition Energy in the glossary",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Was ist der Unterschied zwischen Aktivenergie und Nahrungsenergie?  "
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "What is the difference between Active Energy and Nutrition Energy?"
          }
        }
      }
    },
    "faq.glossary.bmi.answer" : {
      "comment" : "Answer explaining what BMI means in the glossary",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Body-Mass-Index (BMI) ist eine beschreibende Metrik, die Körpergewicht ins Verhältnis zur Körpergröße setzt und häufig als standardisierte Zusammenfassung der Körpermasse verwendet wird. In GluVib wird der BMI auf Basis der in Apple Health verfügbaren Gewichts- und Größendaten berechnet. Wenn Gewichtsdaten fehlen, kann der BMI nicht berechnet oder angezeigt werden. Alle BMI-Anzeigen werden aus Apple-Health-Daten abgeleitet und ausschließlich zu Informationszwecken dargestellt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Body Mass Index (BMI) is a descriptive metric that relates body weight to height and is commonly used as a standardized way to summarize body mass. In GluVib, BMI is calculated based on weight and height data available in Apple Health. If weight data is missing, BMI cannot be calculated or displayed. All BMI displays are derived from Apple Health data and are presented for informational analysis only."
          }
        }
      }
    },
    "faq.glossary.bmi.question" : {
