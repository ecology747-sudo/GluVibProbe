    "faq.free_vs_premium.after_trial_ends.answer" : {
      "comment" : "Answer explaining what happens after the free trial ends",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nach Ablauf der kostenfreien 30-Tage-Testphase läuft GluVib automatisch im Free-Modus weiter, sofern kein Premium-Abonnement über den App Store gestartet wird. Du behältst Zugriff auf die Overviews und die Kernmetriken, die im Free-Modus enthalten sind, während Premium-Metriken und die Metabolik-Domain nicht mehr verfügbar sind. Es werden keine Daten gelöscht, alles bleibt in Apple Health gespeichert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "After the free trial ends, GluVib automatically continues in Free mode unless a Premium subscription is started through the App Store. You will keep access to the Overviews and the core metrics included in Free, while Premium-only metrics and the Metabolic domain become unavailable. No data is deleted; everything remains stored in Apple Health."
          }
        }
      }
    },
