            "value" : "Why can small insulin doses disappear in GluVib?"
          }
        }
      }
    },
    "faq.data_basics.title" : {
      "comment" : "Section title for the data basics FAQ chapter",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Daten-Grundlagen — So funktioniert GluVib."
          }
        },
        "en" : {
          "stringUnit" : {
