      }
    },
    "faq.using_the_app.add_lab_results.answer" : {
      "comment" : "Answer explaining how lab results such as HbA1c can be added",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GluVib unterstützt die manuelle Eingabe von HbA1c-Laborwerten. Diese Werte können in den Einstellungen mit einem bestimmten Datum für Anzeige- und Berichtszwecke eingetragen werden. HbA1c-Einträge werden lokal in der App gespeichert und sind von Apple-Health-Einträgen getrennt. Sie werden nicht über iCloud mit anderen Geräten synchronisiert und beim Deinstallieren der App entfernt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "GluVib supports manual entry of HbA1c laboratory values. These values can be entered in Settings with a specific date for display and reporting purposes. HbA1c entries are stored locally within the app and are separate from Apple Health records. They are not synced to other devices via iCloud and are removed if the app is uninstalled."
          }
        }
      }
    },
    "faq.using_the_app.add_lab_results.question" : {
      "comment" : "Question asking how lab results such as HbA1c can be added",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wie kann ich Laborwerte (z. B. HbA1c) hinzufügen?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "How can I add lab results (e.g., HbA1c)?"
          }
        }
      }
    },
    "faq.using_the_app.change_units.answer" : {
      "comment" : "Answer explaining where units can be changed",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einheiten können in den Einstellungen geändert werden. Änderungen an den Einheiten beeinflussen nur die Darstellung der Werte (Format und Umrechnung), während die zugrunde liegenden Apple-Health-Daten unverändert bleiben. So kann zum Beispiel das Körpergewicht in Kilogramm oder Pfund angezeigt werden, und Distanzwerte können je nach Auswahl in unterschiedlichen Einheitsformaten dargestellt werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Units can be changed in Settings. Unit changes affect how values are displayed (format and conversion), while the underlying Apple Health data remains unchanged. For example, body weight can be displayed in kilograms or pounds, and distance values can be shown in different unit formats depending on your selection."
          }
        }
      }
    },
    "faq.using_the_app.change_units.question" : {
      "comment" : "Question asking where units can be changed",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wo kann ich Einheiten ändern?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Where can I change units?"
          }
        }
      }
    },
    "faq.using_the_app.goals_targets_ranges.answer" : {
      "comment" : "Answer explaining where goals, targets, and ranges can be set",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ziele und Target-Werte können in den Einstellungen konfiguriert werden. Sie dienen als Referenzwerte für Diagramme und KPIs und verändern die in Apple Health gespeicherten Daten nicht. In der Metabolik-Domain können zusätzlich Bereiche konfiguriert werden. Diese Bereiche legen fest, wie zeitbasierte Metriken wie Time in Range bewertet werden und wie zugehörige metabolische Zusammenfassungen und Berechnungen abgeleitet werden. Änderungen an Zielen oder Bereichen beeinflussen also Darstellung und Zusammenfassung, während die zugrunde liegenden Apple-Health-Daten unverändert bleiben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Goals and targets can be configured in Settings. They are used as reference values for charts and KPIs and do not change the underlying data stored in Apple Health. In the Metabolic domain, additional ranges can be configured. These ranges define how time-based metrics such as Time in Range are evaluated and how related metabolic summaries and calculations are derived. Changing goals or ranges affects how data is displayed and summarized, while the underlying Apple Health data remains unchanged."
          }
        }
      }
    },
    "faq.using_the_app.goals_targets_ranges.question" : {
      "comment" : "Question asking where goals, targets, and ranges can be set",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wo kann ich Ziele, Targets und Bereiche festlegen?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Where can I set goals, targets & ranges?"
          }
        }
      }
    },
    "faq.using_the_app.refresh_data.answer" : {
      "comment" : "Answer explaining how to refresh data in the app",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einige Screens unterstützen Pull-to-Refresh. Die Werte für heute können sich ändern, sobald neue Daten in Apple Health verfügbar werden. Vergangene Tage bleiben in der Regel unverändert, da sie historische Aufzeichnungen darstellen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Some screens support pull-to-refresh. Today’s values can change as new data becomes available in Apple Health. Past days typically remain unchanged because they represent historical records."
          }
        }
      }
    },
    "faq.using_the_app.refresh_data.question" : {
      "comment" : "Question asking how to refresh data in the app",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wie aktualisiere ich meine Daten?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "How do I refresh my data?"
          }
        }
      }
    },
    "faq.using_the_app.title" : {
      "comment" : "Section title for the everyday usage FAQ chapter",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App-Nutzung — Alltägliche Fragen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Using the App — Everyday Questions"
          }
        }
      }
    },
    "faq.using_the_app.today_vs_past_days.answer" : {
      "comment" : "Answer explaining why Today behaves differently from past days",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Heute ist ein laufender Tag, an dem im Verlauf des Tages noch neue Daten in Apple Health eintreffen können. Das gilt insbesondere für Daten, die mit Verzögerung synchronisiert werden, wie CGM-(Sensor)Messwerte, die erst Stunden nach der Messung erscheinen können. Deshalb können sich die heutigen Diagramme, KPIs und Abdeckungsanzeigen ändern, sobald zusätzliche Daten verfügbar werden. Vergangene Tage dagegen stellen abgeschlossene Datensätze dar und werden in der App als historische Daten behandelt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Today is an in-progress day where new data may still arrive in Apple Health throughout the day. This applies in particular to data that is synced with a delay, such as CGM (Sensor) readings, which may appear hours after they were measured. As a result, today’s charts, KPIs, and coverage indicators can change as additional data becomes available. Past days, by contrast, represent completed records and are treated as historical data in the app."
          }
        }
      }
    },
