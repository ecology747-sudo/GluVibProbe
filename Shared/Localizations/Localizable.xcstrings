    "faq.general.is_coaching_app.answer" : {
      "comment" : "Answer explaining whether GluVib is a coaching app in the general FAQ section",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nein. GluVib ist keine Coaching-, Motivations- oder Verhaltensänderungs-App. Die App gibt keine Aufforderungen, keine Verhaltensziele und keine personalisierten Handlungsempfehlungen. Aber sie kann motivierend sein :-)."
          }
        },
        "en" : {
