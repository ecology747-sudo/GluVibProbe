            "value" : "Warum können CGM-(Sensor)Daten verzögert erscheinen?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Why can CGM (Sensor) data appear delayed?"
          }
        }
      }
    },
