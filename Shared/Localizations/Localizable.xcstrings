      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GluVib zeigt die meisten Daten an, sobald sie in Apple Health verfügbar sind. Das gilt für Metriken wie Ernährungseinträge, Aktivitäts- und Bewegungsdaten, Workouts und Insulineinträge. Eine Ausnahme bilden kontinuierliche Glukosemessdaten (CGM/Sensordaten) (siehe nächster Punkt).\n"
          }
        },
