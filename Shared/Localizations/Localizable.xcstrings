    "faq.free_vs_premium.trial_30_days.answer" : {
      "comment" : "Answer explaining whether there is a 30-day trial",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ja. Nach der Installation enthält GluVib eine kostenfreie 30-tägige Premium-Testphase. Während dieser Testphase sind alle Premium-Funktionen vollständig verfügbar, einschließlich aller Domains und Metabolik-Funktionen (wenn CGM-(Sensor)Daten in Apple Health vorhanden sind)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Yes. After installation, GluVib includes a free 30-day Premium trial. During the free trial, all Premium features are available, including full domain access and Metabolic features (when CGM (Sensor) data exists in Apple Health)."
          }
        }
      }
    },
