      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die metabolischen Analysen in GluVib basieren auf kontinuierlichen Glukosedaten. Wenn CGM-(Sensor)Daten nicht über Apple Health verfügbar sind, können diese Analysen nicht berechnet oder angezeigt werden."
          }
