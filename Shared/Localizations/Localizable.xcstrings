    "faq.free_vs_premium.what_is_free_vs_premium.answer" : {
      "comment" : "Answer explaining what Free versus Premium means in GluVib",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GluVib bietet zwei Zugriffsvarianten. Free umfasst die Übersichtsseiten für Ernährung, Aktivität und Körper sowie jeweils eine Kernmetrik pro Domain. Premium schaltet vollen Zugriff auf alle Metriken und tiefere Analysen in diesen Domains frei und aktiviert zusätzlich die vollständige Metabolik-Domain mit Report-Ausgabe, wenn CGM-(Sensor)Daten in Apple Health verfügbar sind. Premium beeinflusst nur Sichtbarkeit und Zugriff; deine Apple-Health-Daten bleiben unverändert.\n"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "GluVib offers two access levels. Free includes the main Overviews for Nutrition, Activity, and Body, plus one core metric per domain. Premium unlocks full access to all metrics and deeper analysis across those domains and enables the complete Metabolic domain when CGM (Sensor) data is available in Apple Health. Premium affects visibility and access only; your Apple Health data remains unchanged."
          }
        }
      }
    },
    "faq.free_vs_premium.what_is_free_vs_premium.question" : {
      "comment" : "Question asking what Free versus Premium means in GluVib",
