          }
        }
      }
    },
    "faq.free_vs_premium.what_premium_unlocks.answer" : {
      "comment" : "Answer explaining what Premium unlocks",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Premium schaltet vollen Zugriff auf alle Metriken in Ernährung, Aktivität und Körper frei sowie die Metabolic-Domain (CGM-(Sensor)basierte Analysen, wenn CGM-(Sensor)Daten in Apple Health verfügbar sind). Premium aktiviert außerdem periodenbasierte Zusammenfassungen und strukturierte Berichte auf Basis des ausgewählten Zeitraums. Wenn Insulindaten in Apple Health vorhanden und in den Einstellungen aktiviert sind, können innerhalb der Metabolic-Domain zusätzliche insulinbezogene Auswertungen erscheinen.\n"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Premium unlocks full access to all metrics in Nutrition, Activity, and Body, plus the Metabolic domain (CGM (Sensor)-based analytics when CGM (Sensor) data is available in Apple Health). Premium also enables period-based analytical summaries and structured reports derived from the selected time range. If insulin data exists in Apple Health and is enabled in Settings, optional insulin-related evaluations can appear within the Metabolic domain."
          }
        }
      }
    },
    "faq.free_vs_premium.what_premium_unlocks.question" : {
