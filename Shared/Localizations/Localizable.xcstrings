    "onboarding.flow.ready.body" : {
      "comment" : "Description text for the final ready step in onboarding",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GluVib ist jetzt vollständig eingerichtet und bereit, von dir erkundet zu werden. Starte mit deiner kostenfreien 30-Tage-Testphase und erhalte Zugriff auf alle Funktionen. Einheiten, Ziele und Sichtbarkeiten kannst du jederzeit in den Einstellungen anpassen. Wenn du Feedback hast, freuen wir uns darauf. Viel Freude mit GluVib! Dein GluVib-Team."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "GluVib is now fully set up and ready for you to explore. Experience your free 30-day trial with access to all features. You can personalize units, goals, and visibility anytime in the settings. If you have feedback, we’d love to hear it. Enjoy your journey! Your Team GluVib!"
          }
        }
      }
    },
