    "privacy.hero" : {
      "comment" : "Hero intro text at the top of the privacy policy",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GluVib ist eine App mit rein lesendem Zugriff zur Visualisierung und Zusammenfassung von in Apple Health gespeicherten Gesundheitsdaten. GluVib bietet keine medizinische Beratung, Diagnose oder Behandlung. Die gesamte Verarbeitung erfolgt lokal auf deinem Gerät, und es werden keine Gesundheitsdaten auf externe Server hochgeladen. Ausnahme: Wenn du Laborwerte, zum Beispiel HbA1c, manuell hinzufügst, werden diese Einträge lokal in der App gespeichert und nicht über iCloud mit anderen Geräten synchronisiert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "GluVib is a read-only app for visualizing and summarizing health data stored in Apple Health. GluVib does not provide medical advice, diagnosis, or treatment. All processing happens locally on your device, and no health data is uploaded to external servers. Exception: if you manually add lab values (for example HbA1c), those entries are stored locally inside the app and are not synced to other devices via iCloud."
          }
        }
      }
    },
