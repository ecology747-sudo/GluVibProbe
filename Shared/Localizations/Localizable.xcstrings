    "faq.reports.how_used_and_shared.answer" : {
      "comment" : "Answer explaining how the report can be used and shared",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der GluVib Metabolic & Lifestyle Report kann als PDF zum Drucken exportiert oder digital geteilt werden. Da der Bericht sensible persönliche Gesundheitsinformationen enthalten kann, zeigt GluVib vor dem Export oder Teilen einen Bestätigungsschritt an. Alle Berichtsinhalte werden aus den in Apple Health verfügbaren Daten abgeleitet und spiegeln den ausgewählten Zeitraum sowie die zum Zeitpunkt der Erstellung aktivierten Funktionen wider."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "The GluVib Metabolic & Lifestyle Report can be exported as a PDF for printing or shared digitally. Because the report may contain sensitive personal health information, GluVib presents a confirmation step before export or sharing. All report content is derived from the data available in Apple Health and reflects the selected time period and enabled features at the time of generation."
          }
        }
      }
    },
    "faq.reports.how_used_and_shared.question" : {
      "comment" : "Question asking how the report can be used and shared",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wie kann der Bericht genutzt und geteilt werden?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "How can the report be used and shared?"
          }
        }
      }
    },
    "faq.reports.title" : {
      "comment" : "Section title for the reports FAQ chapter",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berichte — GluVib Metabolic & Lifestyle Report"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Reports — GluVib Metabolic & Lifestyle Report"
          }
        }
      }
    },
    "faq.reports.what_is_report.answer" : {
      "comment" : "Answer explaining what the GluVib Metabolic & Lifestyle Report is",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der GluVib Metabolic & Lifestyle Report ist ein nur für Premium verfügbarer, druck- und teilbarer PDF-Bericht, der für die strukturierte Übersicht persönlicher Gesundheitsdaten konzipiert ist — basierend auf dem, was in Apple Health verfügbar ist. Der Bericht konzentriert sich vor allem auf metabolische Analysen, einschließlich CGM-(Sensor-)basierter Glukosemetriken und Visualisierungen. Insulinbezogene Analysen können enthalten sein, wenn Insulindaten verfügbar und in den Einstellungen aktiviert sind. Der Bericht dient ausschließlich Informationszwecken und gibt keine medizinische Beratung, Diagnose oder Therapieempfehlung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "The GluVib Metabolic & Lifestyle Report is a Premium-only, printable and shareable PDF report designed for structured review of personal health data based on what is available in Apple Health. The report focuses primarily on metabolic analytics, including CGM (Sensor)-based glucose metrics and visualizations. Insulin-related analyses can be included when insulin data is available and enabled in Settings. The report is intended for informational and analytical purposes only and does not provide medical advice, diagnosis, or therapy recommendations."
          }
        }
      }
    },
    "faq.reports.what_is_report.question" : {
      "comment" : "Question asking what the GluVib Metabolic & Lifestyle Report is",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Was ist der GluVib Metabolic & Lifestyle Report?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "What is the GluVib Metabolic & Lifestyle Report?"
          }
        }
      }
    },
    "faq.troubleshooting.different_values.answer" : {
      "comment" : "Answer explaining why GluVib can show different values compared to another app",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unterschiede können entstehen, wenn Datenquellen Werte unterschiedlich in Apple Health schreiben, wenn Zeitfenster oder Einheiten abweichen oder wenn die Daten in Apple Health unvollständig oder verzögert sind. GluVib verändert Gesundheitsdaten nicht und kann nur anzeigen, was in Apple Health gespeichert ist. Deshalb spiegelt die Ausgabe die in Apple Health verfügbaren Werte und Zeitstempel wider."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Differences can occur when data sources write values differently into Apple Health, when time windows or units differ, or when the data in Apple Health is incomplete or delayed. GluVib does not modify health data and can only display what is recorded in Apple Health, so the output reflects Apple Health’s available values and timestamps."
          }
        }
      }
    },
    "faq.troubleshooting.different_values.question" : {
      "comment" : "Question asking why GluVib can show different values compared to another app",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Warum zeigt GluVib andere Werte als eine andere App?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Why does GluVib show different values compared to another app?"
          }
        }
      }
    },
    "faq.troubleshooting.exclamation_mark_metric.answer" : {
      "comment" : "Answer explaining what the exclamation mark means on a metric",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Ausrufezeichen bedeutet, dass GluVib diesen spezifischen Datentyp aktuell nicht aus Apple Health lesen kann (keine Leseerlaubnis oder keine Daten in Apple Health). Je nachdem, wo du es siehst, kann das zum Beispiel Daten wie Schritte (Aktivität), Schlaf, Ernährungseinträge (Carbs/Protein/Fat/Energy) oder Körpermetriken (Gewicht/BMI/Körperfett) betreffen. Es bedeutet nicht, dass deine Werte „schlecht“ sind — es zeigt nur an, dass GluVib keine Berechtigung hat, diesen Datentyp zu lesen, oder dass der Zugriff später in Apple Health bzw. den iOS-Einstellungen deaktiviert wurde.\n"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "The exclamation mark means GluVib currently cannot read that specific data type from Apple Health. Depending on where you see it, this can refer to data such as Steps (Activity), Sleep, Nutrition entries (Carbs/Protein/Fat/Energy), or Body metrics (Weight/BMI/Body Fat). It does not mean your values are “bad” — it only indicates that GluVib does not have permission to read that data type, or that access was later disabled in Apple Health / iOS settings."
          }
        }
      }
    },
    "faq.troubleshooting.exclamation_mark_metric.question" : {
      "comment" : "Question asking what the exclamation mark means on a metric",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Was bedeutet das das rote Badge mit Ausrufezeichen (!) bei einer Metrik?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "What does the exclamation mark (!) mean on a metric?"
          }
        }
      }
    },
    "faq.troubleshooting.features_not_visible.answer" : {
      "comment" : "Answer explaining why some features or sections are not visible",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Sichtbarkeit von Funktionen und Bereichen hängt von deinem Zugriffslevel (Free vs Premium), deiner Konfiguration in den Einstellungen und davon ab, ob relevante Daten in Apple Health vorhanden sind. Metabolische Bereiche benötigen CGM-(Sensor-)Daten in Apple Health, und optionale insulinbezogene Ansichten benötigen zusätzlich Insulindaten sowie den entsprechenden Status in den Einstellungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Feature and section visibility depends on your access level (Free vs Premium), your Settings configuration, and whether relevant data exists in Apple Health. Metabolic sections require CGM (Sensor) data in Apple Health, and optional insulin-related views require insulin data plus the corresponding Settings status."
          }
        }
      }
    },
    "faq.troubleshooting.features_not_visible.question" : {
      "comment" : "Question asking why some features or sections are not visible",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Warum sind manche Funktionen oder Bereiche nicht sichtbar?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Why are some features or sections not visible?"
          }
        }
      }
    },
    "faq.troubleshooting.hide_exclamation_marks.answer" : {
      "comment" : "Answer explaining whether the exclamation marks can be hidden",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ja. Du kannst Permission Warnings in den Einstellungen deaktivieren. Wenn diese Option ausgeschaltet ist, zeigt GluVib weder Ausrufezeichen noch Berechtigungswarnungen an. Du kannst sie jederzeit wieder aktivieren oder die Health-Berechtigungen für GluVib in Apple Health bzw. den iOS-Einstellungen prüfen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Yes. You can turn off Permission Warnings in Settings. When disabled, GluVib will not show exclamation marks or permission warning messages. You can enable them again at any time, or review the Health permissions for GluVib in Apple Health / iOS settings."
          }
        }
      }
    },
    "faq.troubleshooting.hide_exclamation_marks.question" : {
      "comment" : "Question asking whether the exclamation marks can be hidden",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kann ich die Ausrufezeichen ausblenden?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Can I hide the exclamation marks?"
          }
        }
      }
    },
    "faq.troubleshooting.metric_empty.answer" : {
      "comment" : "Answer explaining why a metric is empty",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine Metrik kann leer sein, wenn Apple Health für den ausgewählten Zeitraum keine Werte enthält, wenn Daten verzögert sind oder wenn GluVib keine Berechtigung hat, diesen Datentyp zu lesen. GluVib erzeugt oder repariert keine Gesundheitsdaten; die App kann nur lesen und anzeigen, was in Apple Health verfügbar ist. Wenn in Apple Health keine Daten vorhanden sind, kann GluVib für diese Metrik keine Werte abrufen oder anzeigen. Einige Metriken benötigen außerdem eine Mindestmenge an Datenabdeckung, um sinnvolle Zusammenfassungen zu erzeugen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "A metric can be empty when Apple Health does not contain values for the selected period, when data is delayed, or when GluVib does not have permission to read that data type. GluVib does not generate or repair health data; it can only read and display what is available in Apple Health. If no data is present in Apple Health, GluVib cannot retrieve or present values for that metric. Some metrics also require a minimum amount of data coverage to produce meaningful summaries."
          }
        }
      }
    },
    "faq.troubleshooting.metric_empty.question" : {
      "comment" : "Question asking why a metric is empty",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Warum ist eine Metrik leer?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Why is a metric empty?"
          }
        }
      }
    },
    "faq.troubleshooting.no_data_at_all.answer" : {
      "comment" : "Answer explaining why the no data available at all message appears",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Meldung bedeutet, dass GluVib in Apple Health keine nutzbaren Daten für diese Metrik finden kann. Das kann passieren, wenn die Metrik nie erfasst wurde, wenn die Quell-App oder das Gerät keine Werte nach Apple Health geschrieben oder synchronisiert hat oder wenn GluVib keine Berechtigung hat, den benötigten Datentyp zu lesen. Da GluVib ausschließlich Daten aus Apple Health liest und anzeigt, bleiben Metriken leer, wenn dort keine relevanten Daten vorhanden sind oder wenn der Apple-Health-Zugriff widerrufen wurde."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "This message means that GluVib cannot find any usable data for this metric in Apple Health. This can happen if the metric has never been recorded, if the source app or device has not written or synced any values to Apple Health, or if GluVib does not have permission to read the required data type. Because GluVib only reads and displays data from Apple Health, metrics will remain empty if no relevant data is present there or if Apple Health access has been revoked."
          }
        }
      }
    },
    "faq.troubleshooting.no_data_at_all.question" : {
      "comment" : "Question asking why the no data available at all message appears",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Warum sehe ich eine Meldung, dass überhaupt keine Daten verfügbar sind?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Why do I see a message saying that no data is available at all?"
          }
        }
      }
    },
    "faq.troubleshooting.no_data_for_today.answer" : {
      "comment" : "Answer explaining why the no data for today message appears",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Meldung bedeutet, dass GluVib für diese Metrik auf historische Daten zugreifen kann, aber für heute noch kein Wert aufgezeichnet wurde. Das ist typisch für Metriken, die von täglichen Messungen oder Ereignissen abhängen, wie Körpermetriken, Ernährungseinträge, Insulindosen oder Ruheherzfrequenz. Sobald Apple Health einen Wert für heute erhält, verschwindet die Meldung automatisch."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "This message means that GluVib has access to historical data for this metric, but no value has been recorded yet for today. This is common for metrics that depend on daily measurements or events, such as body metrics, nutrition entries, insulin doses, or resting heart rate. As soon as Apple Health receives a value for today, the message will disappear automatically."
          }
        }
      }
    },
    "faq.troubleshooting.no_data_for_today.question" : {
      "comment" : "Question asking why the no data for today message appears",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Warum sehe ich eine Meldung wie „Keine Daten für heute“?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Why do I see a message saying “No data for today”?"
          }
        }
      }
    },
    "faq.troubleshooting.title" : {
      "comment" : "Section title for the troubleshooting FAQ chapter",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
