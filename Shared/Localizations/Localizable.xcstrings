          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "What are the main limitations of GluVib?"
          }
        }
      }
    },
    "faq.general.medical_recommendations.answer" : {
      "comment" : "Answer explaining whether GluVib provides medical recommendations in the general FAQ section",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nein. GluVib gibt keine medizinische Beratung, keine Diagnose, keine Therapieempfehlungen und keine Behandlungshinweise. Alle Werte und Diagramme sind rein informative Darstellungen der verfügbaren Daten. Für die Richtigkeit der Input-Daten in Apple-Health bist du verantwortlich!"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "No. GluVib does not provide medical advice, diagnosis, therapy recommendations, or treatment guidance. Any values and charts are informational displays of available data."
          }
        }
