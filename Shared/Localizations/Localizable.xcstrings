    "faq.hardware_system_requirements.apple_watch_needed.answer" : {
      "comment" : "Answer explaining whether an Apple Watch is needed",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nein. Eine Apple Watch ist optional. Wenn sie vorhanden ist, kann sie die Datenvollständigkeit für bestimmte Metriken wie Aktivität, Herzfrequenz und Schlaf verbessern — abhängig davon, was in Apple Health aufgezeichnet wird.\n"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "No. An Apple Watch is optional. If present, it can improve data completeness for certain metrics such as activity, heart rate, and sleep, depending on what is recorded into Apple Health."
          }
        }
      }
    },
    "faq.hardware_system_requirements.apple_watch_needed.question" : {
