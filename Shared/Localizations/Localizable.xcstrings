          }
        }
      }
    },
    "faq.hardware_system_requirements.ipad_requirements.answer" : {
      "comment" : "Answer explaining which iPad devices and system version are required",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GluVib läuft auf iPad-Modellen, die iPadOS 17 oder neuer unterstützen. Apple Health muss auf dem Gerät verfügbar und mit GluVib verbunden sein, damit die App Gesundheitsdaten lesen kann."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "GluVib runs on iPad models that support iPadOS 17 or later. Apple Health must be available on the device and connected to GluVib so the app can read health data."
          }
        }
      }
    },
    "faq.hardware_system_requirements.ipad_requirements.question" : {
