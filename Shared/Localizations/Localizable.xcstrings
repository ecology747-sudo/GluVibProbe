    },
    "(%@)" : {
      "comment" : "A sublabel below a movement split card item, showing the duration of that activity. The argument is the duration of the activity, expressed in minutes.",
      "isCommentAutoGenerated" : true
    },
    "(<%lld%%)" : {
      "comment" : "A text label indicating that the value is below the target value.",
      "isCommentAutoGenerated" : true
    },
    "(24h)" : {
      "comment" : "A suffix indicating that the glucose value is for the last 24 hours.",
      "isCommentAutoGenerated" : true
    },
    "%" : {
      "comment" : "A space to align the text with the other elements in the row.",
      "isCommentAutoGenerated" : true
    },
    "%@" : {
      "comment" : "The main title of the report view.",
      "isCommentAutoGenerated" : true
    },
    "%@ %@" : {
      "comment" : "A text field displaying a glucose value with its unit. The argument is the glucose value.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ %2$@"
          }
